#!/bin/sh
# 推送门禁逐行读取 Git 提供的 local/remote ref 更新，验证真正将被发送的 commit，而不是
# 当前工作树。main 允许在轻量检查通过后直接更新；历史 XAGE 继续只读。
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"
local_git_env=$(git rev-parse --local-env-vars)
clean_git() (
  unset $local_git_env
  git "$@"
)

zero=0000000000000000000000000000000000000000
active_snapshot=""
snapshot_parent=""
cleanup() {
  if [ -n "$active_snapshot" ]; then
    clean_git -C "$repo_root" worktree remove --force "$active_snapshot" >/dev/null 2>&1 || true
    active_snapshot=""
  fi
  if [ -n "$snapshot_parent" ]; then
    rmdir "$snapshot_parent" >/dev/null 2>&1 || true
    snapshot_parent=""
  fi
}
trap cleanup EXIT
trap 'cleanup; exit 1' HUP INT TERM

while read local_ref local_sha remote_ref remote_sha; do
  # 历史 XAGE 仍禁止更新或删除；main 走与普通分支相同的待推送差异检查。
  case "$remote_ref" in
    refs/heads/XAGE)
      echo "Direct updates or deletions of read-only legacy branch $remote_ref are forbidden." >&2
      exit 1
      ;;
  esac
  if [ "$local_sha" = "$zero" ]; then
    # 删除普通 feature branch 不含候选 commit，无需建立验证快照。
    continue
  fi
  base=$remote_sha
  if [ "$base" = "$zero" ]; then
    # 新建远端分支没有 remote_sha，以 origin/main merge-base 作为比较基线；找不到 canonical
    # main 时拒绝推送，避免把整段未知历史当作一个无法分类的候选。
    if git show-ref --verify --quiet refs/remotes/origin/main; then
      base=$(git merge-base "$local_sha" refs/remotes/origin/main)
    else
      echo "Cannot validate a new branch without refs/remotes/origin/main" >&2
      exit 1
    fi
  fi

  # 默认 push 门禁只检查真实待推送 commit range 的空白；完整 detached worktree guard
  # 仍保留在下方，并可通过 XJIE_STRICT_GATES=1 恢复。
  if [ "${XJIE_STRICT_GATES:-0}" != "1" ]; then
    git diff --check "$base" "$local_sha"
    continue
  fi

  # 每个 ref 使用独立 detached worktree。验证结束立即清理，多个 ref 不共享状态或结果。
  snapshot_parent=$(mktemp -d "${TMPDIR:-/tmp}/xjie-prepush.XXXXXX")
  active_snapshot="$snapshot_parent/candidate"
  clean_git -C "$repo_root" worktree add --detach --quiet "$active_snapshot" "$local_sha"
  (
    unset $local_git_env
    cd "$active_snapshot"
    /usr/bin/python3 -I tools/regression_guard.py check --base "$base" --head "$local_sha"
  )
  cleanup
done
