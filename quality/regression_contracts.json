  "conservative_overrides": [
    {
      "pattern": "Xjie/Xjie/Views/Home/XAgeMainView.swift",
      "verification_domains": [
        "ios_ui_interaction",
        "ios_chat_client",
        "ios_health_client",
        "ios_account_client"
      ],
      "reason": "该文件当前同时承载数据、问答、X年龄、设置、账号、上传、键盘和导航；拆分完成前任何修改都按全域风险处理。"
    },
    {
      "pattern": "Xjie/Xjie/Services/APIService*.swift",
      "verification_domains": [
        "ios_core",
        "ios_chat_client",
        "ios_health_client",
        "ios_account_client"
      ],
      "reason": "共享 API 服务同时承载聊天、健康、账号和通用请求；修改必须运行所有消费者的既有契约。"
    }
  ],
  "architecture_limits": [
    {
      "path": "Xjie/Xjie/Views/Home/XAgeMainView.swift",
      "max_lines": 10305,
      "pattern_limits": [
        {"name": "struct declarations", "pattern": "\\bstruct\\s+[A-Za-z_]", "max_count": 100},
        {"name": "enum declarations", "pattern": "\\benum\\s+[A-Za-z_]", "max_count": 16},
        {"name": "sheet presentations", "pattern": "\\.sheet\\s*\\(", "max_count": 19},
        {"name": "full-screen presentations", "pattern": "\\.fullScreenCover\\s*\\(", "max_count": 6},
        {"name": "alerts", "pattern": "\\.alert\\s*\\(", "max_count": 20},
        {"name": "fixed presentation delays", "pattern": "asyncAfter\\s*\\(", "max_count": 7},
        {"name": "silenced API failures", "pattern": "try\\?\\s+await\\s+api\\.", "max_count": 2}
      ],
      "forbidden_patterns": [
        {"name": "legacy HomeView route", "pattern": "\\bHomeView\\s*\\("},
        {"name": "legacy ChatView route", "pattern": "\\bChatView\\s*\\("},
        {"name": "legacy SettingsView route", "pattern": "\\bSettingsView\\s*\\("},
        {"name": "legacy MedicationListView route", "pattern": "\\bMedicationListView\\s*\\("}
      ]
    }
  ],
  "contracts": [
    {
      "id": "UX-NAV-001",
      "domains": ["ios_ui_interaction"],
      "invariant": "页面式任务使用系统导航返回；sheet 的拖拽暗示、交互式关闭和显式关闭行为必须一致。",
      "test_anchors": [
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testMetricManagerPageAndChatKeyboardLifecycle"},
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testNavigationTouchTargetsAndFormDismissalConventions"}
      ]
    },
    {
      "id": "UX-KEYBOARD-001",
      "domains": ["ios_ui_interaction", "ios_chat_client"],
      "invariant": "点击空白、明显纵向下拉、打开菜单或附件、切换三栏和离开页面时释放焦点；聊天输入框保持 1–5 行自适应，Return 只插入换行且不得发送或关闭键盘，纸飞机是唯一草稿发送动作；中文输入不回写旧草稿。",
      "test_anchors": [
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testMetricManagerPageAndChatKeyboardLifecycle"},
        {"path": "Xjie/XjieTests/ChatViewModelTests.swift", "symbol": "testSendTextClearsMatchingIMECommitButPreservesNewerDraft"}
      ]
    },
    {
      "id": "UX-CHAT-QUIESCENCE-001",
      "domains": ["ios_ui_interaction", "ios_chat_client"],
      "invariant": "连续聊天从不可滚动进入可滚动时，自动定位不得排队或叠加动画；XAGE 与旧聊天必须各保留唯一且顺序固定的底部 anchor，并只经同步禁动画 ChatAutoScroll 定位。Return 只换行，纸飞机是唯一草稿发送动作；发送必须先同步捕获不可变草稿、失焦并显式关闭键盘，之后才能启动异步任务，快捷问题、初始提示、重试、同意后继续、报告上传后续以及所有相邻 outbound 方法/别名也不得绕过审计 wiring。thinking 与 upload 状态卡必须共用 ChatProgressIndicator，仅明确 Debug UI automation 使用静态图标，普通 Debug/Release 使用正常 ProgressView；除该视觉状态外，Release 与 UI automation 的 anchor、真实消息/Markdown consumer、辅助功能树、发送 wiring、生命周期值和终态不得分叉。视觉不变的普通正文必须使用纯文本视觉/辅助功能树，当前 inline renderer 支持的 Markdown 必须保留原视觉富文本和去标记阅读顺序，真实链接必须保持可激活且可命中的 Link 角色；最终唯一收口为 idle、sending=false、thinking 消失、精确 user/assistant 消息数、latest=assistant 和 focused=false。policy test 必须实际构造并拒绝当前 68 个对抗变异，锁定 anchor/order、完整多行编辑与终态、Link 断言、真实 consumer、完整根消费者、条件编译块、共享 UI 等待/网络审计和全部发送入口。",
      "test_anchors": [
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testHighIntensityContextFlowUsesDeterministicChatTransportAndVerifiesAllPrompts"},
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testMetricManagerPageAndChatKeyboardLifecycle"},
        {"path": "Xjie/XjieTests/ChatViewModelTests.swift", "symbol": "testSendMessageAppendsUserMessage"},
        {"path": "tools/tests/test_release_policy.py", "symbol": "test_required_ui_tests_use_single_deterministic_app_factory_and_audit"}
      ]
    },
    {
      "id": "UX-ACCESSIBILITY-001",
      "domains": ["ios_ui_interaction"],
      "invariant": "主要操作的真实可访问命中区至少 44pt，父级标签不得覆盖子按钮，禁用态和危险操作语义准确。",
      "test_anchors": [
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testNavigationTouchTargetsAndFormDismissalConventions"}
      ]
    },
    {
      "id": "UX-FORM-001",
      "domains": ["ios_ui_interaction", "ios_account_client"],
      "invariant": "干净表单可按系统习惯退出；脏表单必须确认放弃；提交中防重复；破坏性操作必须二次确认。",
      "test_anchors": [
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testNavigationTouchTargetsAndFormDismissalConventions"},
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testLoginKeyboardToolbarAndPasswordVisibilityFocus"}
      ]
    },
    {
      "id": "DATA-CARD-001",
      "domains": ["ios_ui_interaction", "ios_health_client"],
      "invariant": "用户的数据卡片选择、顺序和移出状态按账号持久化，同步只能更新内容，不能偷偷恢复已移出的卡片。",
      "test_anchors": [
        {"path": "Xjie/XjieUITests/XAgeHighIntensityContextUITests.swift", "symbol": "testDataCardManagerPersistsSelectedCardsAcrossRelaunch"},
        {"path": "Xjie/XjieTests/AppleHealthSyncViewModelTests.swift", "symbol": "testDashboardCardPreferencesAreIsolatedAndLegacyMigrationIsSingleUse"}
      ]
    },
    {
      "id": "CHAT-SESSION-001",
      "domains": ["ios_chat_client", "backend_chat_ai"],
      "invariant": "重试沿用同一 client_message_id；新会话、切账号或切主体后，旧请求的迟到回答不得写入当前界面。",
      "test_anchors": [
        {"path": "Xjie/XjieTests/ChatViewModelTests.swift", "symbol": "testNewChatWhileRequestIsInFlightDoesNotReceiveOldAnswer"},
        {"path": "backend/tests/unit/test_chat_execution_pipeline.py", "symbol": "test_sse_pipeline_emits_route_then_done_and_replays_idempotently"}
      ]
    },
    {
      "id": "AI-SUBJECT-001",
      "domains": ["backend_chat_ai"],
      "invariant": "非本人问题不得使用登录用户的健康数据，主体纠正和多轮代词不得重新串回本人。",
      "test_anchors": [
        {"path": "backend/tests/unit/test_chat_message_structure.py", "symbol": "test_mother_glucose_query_blocks_self_cgm_data"},
        {"path": "backend/tests/unit/test_chat_message_structure.py", "symbol": "test_subject_switch_prevents_relative_pregnancy_trait_from_leaking_to_self"}
      ]
    },
    {
      "id": "AI-SAFETY-001",
      "domains": ["backend_chat_ai"],
      "invariant": "急症与确定性高风险优先于 LLM；不得给出延误急救、自行加减停药或绝对安全保证。",
      "test_anchors": [
        {"path": "backend/tests/unit/test_chat_routing.py", "symbol": "test_emergency_route_has_priority_over_every_other_hint"},
        {"path": "backend/tests/unit/test_numeric_health_risk.py", "symbol": "test_severe_blood_pressure_with_neurologic_symptom_is_emergency"}
      ]
    },
    {
      "id": "AI-EVIDENCE-001",
      "domains": ["ios_chat_client", "backend_chat_ai"],
      "invariant": "正文角标、证据卡、幂等重放和历史快照必须一致；不允许把错误论文换绑到结论。",
      "test_anchors": [
        {"path": "Xjie/XjieTests/ChatMessageTests.swift", "symbol": "testRelevantCitationReferencesKeepsCompactedBackendNumbering"},
        {"path": "backend/tests/unit/test_chat_citations.py", "symbol": "test_wrong_marker_is_removed_instead_of_rebound_to_better_matching_paper"}
      ]
    },
    {
      "id": "HEALTH-REGISTRY-001",
      "domains": ["ios_health_client", "backend_health_sync"],
      "invariant": "健康目录、读取、上传和趋势使用同一稳定 registry；支持项真实读取，不支持项明确说明。",
      "test_anchors": [
        {"path": "Xjie/XjieTests/AppleHealthSyncViewModelTests.swift", "symbol": "testRegistryCoversEveryCatalogMetricAndExplicitlyMarksNonStandardTypes"},
        {"path": "Xjie/XjieTests/AppleHealthSyncViewModelTests.swift", "symbol": "testAppleHealthCatalogOnlyPromisesAutomaticSyncForImplementedMetrics"}
      ]
    },
    {
      "id": "HEALTH-ACCOUNT-001",
      "domains": ["ios_health_client", "backend_health_sync"],
      "invariant": "健康同步绑定当前账号并拒绝旧账号迟到回调；设备数据不得覆盖手工记录，来源身份必须幂等。",
      "test_anchors": [
        {"path": "Xjie/XjieTests/AppleHealthSyncViewModelTests.swift", "symbol": "testBackgroundObserverUploadsOnceAndRejectsLatePreviousAccountCallback"},
        {"path": "backend/tests/unit/test_device_indicator_sync.py", "symbol": "test_apple_health_never_overwrites_manual_value"}
      ]
    },
    {
      "id": "TEST-SUITE-INTEGRITY-001",
      "domains": ["test_suite_integrity"],
      "invariant": "测试与精确运行清单只能单调增强；删除断言、skip、collection disable、参数化收缩、测试 ID 删除或改名必须失败。",
