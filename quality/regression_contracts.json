        "Xjie/Xjie/Views/**/*.swift",
        "Xjie/Xjie/App/**/*.swift",
        "Xjie/Xjie/Assets.xcassets/**",
        "Xjie/Xjie/Resources/**"
      ],
      "test_patterns": [
        "Xjie/XjieUITests/**/*.swift"
      ],
      "meaningful_test_patterns": [
        "\\bfunc\\s+test",
        "XCTAssert",
        "waitForExistence",
        "\\.tap\\(",
        "\\.swipe",
        "typeText\\(",
        "press\\(forDuration"
      ],
      "verification_commands": [
        "ios_unit",
        "ios_ui_full",
        "ios_ui_small",
        "ios_release_build"
      ]
    },
    {
