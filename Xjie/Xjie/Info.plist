<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>小捷</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>健康报告与图片</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.adobe.pdf</string>
				<string>public.pdf</string>
				<string>public.image</string>
				<string>public.jpeg</string>
				<string>public.png</string>
				<string>public.heic</string>
				<string>public.heif</string>
				<string>public.tiff</string>
			</array>
		</dict>
	</array>
	<key>API_BASE_URL</key>
	<string>https://www.jianjieaitech.com</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>需要使用相机拍摄膳食/体检报告等照片，用于记录与上传分析。</string>
	<key>NSHealthShareUsageDescription</key>
	<string>在你选择授权后，小捷会只读 Apple 健康中的活动、身体测量、心脏与呼吸、睡眠、营养、血糖与胰岛素、声音环境，以及经期、排卵和性活动等生理记录，并在前台或后台同步到当前登录账号的健康趋势；未授权项目不会读取。</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>小捷当前不会向 Apple 健康写入数据；未来如提供写入功能，会在操作前另行说明并再次请求你的授权。</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>需要使用麦克风进行助手小捷语音输入。</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>需要将拍摄的膳食照片保存到相册（可选）。</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>需要访问相册以选择膳食/体检报告等照片用于上传。</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>需要使用语音识别将您的语音转换成文字消息。</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
		<key>UIImageName</key>
		<string></string>
	</dict>
</dict>
</plist>
