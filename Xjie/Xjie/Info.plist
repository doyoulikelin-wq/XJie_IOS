<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>小捷</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>健康报告与图片</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.adobe.pdf</string>
				<string>public.pdf</string>
				<string>public.image</string>
				<string>public.jpeg</string>
				<string>public.png</string>
				<string>public.heic</string>
				<string>public.heif</string>
				<string>public.tiff</string>
			</array>
		</dict>
	</array>
	<key>API_BASE_URL</key>
	<string>https://www.jianjieaitech.com</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>需要使用相机拍摄膳食/体检报告等照片，用于记录与上传分析。</string>
	<key>NSHealthShareUsageDescription</key>
	<string>需要读取 Apple 健康中的步数、睡眠、心率、HRV 等数据，用于同步到服务器并更新用户端健康趋势。</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>需要在用户授权后将小捷记录的健康指标同步回 Apple 健康，用于保持健康记录和趋势一致。</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>需要使用麦克风进行助手小捷语音输入。</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>需要将拍摄的膳食照片保存到相册（可选）。</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>需要访问相册以选择膳食/体检报告等照片用于上传。</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>需要使用语音识别将您的语音转换成文字消息。</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
		<key>UIImageName</key>
		<string></string>
	</dict>
</dict>
</plist>
